{{define "toc"}}
{{with .Markdown}}
{{with .Toc}}
{{with .Children}}
{{with (index . 0)}}
{{if gt (len .Children) 0}}
<aside id="toc" style="display:none">
  <ul>
    {{range .Children}}
    <li><a href="#{{.ID}}" class="toc{{.Level}}">{{.Title}}</a>
      <div class="skeleton"></div>
    </li>
    {{end}}
    <li><a href="#">↑</a>
      <div class="skeleton"></div>
    </li>
  </ul>
  <div class="shade"></div>
  {{end}}
</aside>
<script src="/.assets/toc.js" defer></script>
{{end}}
{{end}}
{{end}}
{{end}}
{{end}}